{
  "expo": {
    "name": "ReminDrugs",
    "slug": "remindrugs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "remindrugs",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSHealthShareUsageDescription": "ReminDrugs reads your sleep and heart rate data to show health insights alongside your medication schedule.",
        "NSHealthUpdateUsageDescription": "ReminDrugs does not write health data."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#16A34A",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.WAKE_LOCK"
      ],
      "package": "com.rayhunts.remindrugs"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-screen.png",
          "backgroundColor": "#16A34A",
          "resizeMode": "contain"
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-sharing",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/pill_bottle_shake.mp3"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow ReminDrugs to access your camera to scan prescriptions.",
          "photosPermission": "Allow ReminDrugs to access your photos to scan prescriptions."
        }
      ],
      [
        "rn-mlkit-ocr",
        {
          "ocrModels": [
            "latin"
          ],
          "ocrUseBundled": true
        }
      ],
      "expo-localization",
      "./modules/expo-fullscreen-alarm",
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "068297a6-98f2-455c-83bd-a081e060bfd6"
      }
    }
  }
}
